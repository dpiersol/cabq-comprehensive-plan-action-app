{
  "name": "cabq-comprehensive-plan-action-app",
  "private": true,
  "version": "4.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:uiux": "vite --port 5175 --strictPort",
    "dev:develop": "vite --port 5176 --strictPort",
    "dev:server": "tsx server/index.ts",
    "dev:all": "concurrently -k \"npm run dev:server\" \"npm run dev\"",
    "dev:all:uiux": "concurrently -k \"npm run dev:server\" \"npm run dev:uiux\"",
    "dev:all:develop": "concurrently -k \"npm run dev:server\" \"npm run dev:develop\"",
    "build": "tsc -b && vite build",
    "build:e2e": "tsc -b && vite build --mode e2e",
    "preview": "vite preview",
    "e2e:serve": "concurrently -k \"npm run dev:server\" \"npx wait-on http://127.0.0.1:8787/api/health && vite preview --host 127.0.0.1 --port 4173 --strictPort\"",
    "test": "vitest run",
    "test:e2e": "npm run build:e2e && playwright test",
    "test:e2e:ui": "npm run build:e2e && playwright test --ui",
    "lint": "eslint .",
    "data": "python scripts/excel_to_hierarchy.py",
    "deploy:sandbox": "powershell -ExecutionPolicy Bypass -File scripts/push-to-sandbox.ps1"
  },
  "dependencies": {
    "@azure/msal-browser": "^5.3.0",
    "@azure/msal-react": "^5.3.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/rate-limit": "^10.3.0",
    "@tiptap/extension-link": "^3.22.0",
    "@tiptap/extension-placeholder": "^3.22.0",
    "@tiptap/extension-underline": "^3.22.0",
    "@tiptap/react": "^3.22.0",
    "@tiptap/starter-kit": "^3.22.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.9.0",
    "docxtemplater": "^3.67.4",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.4",
    "jose": "^6.2.2",
    "libreoffice-convert": "^1.7.0",
    "pdfkit": "^0.17.2",
    "pizzip": "^3.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.1",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@playwright/test": "^1.59.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "@types/pdfkit": "^0.17.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.3",
    "vitest": "^4.1.2",
    "wait-on": "^9.0.3"
  }
}
