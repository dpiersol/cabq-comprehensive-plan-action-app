# Testing branch — force mock sign-in so Dev User Login / Dev Admin Login appear on the landing page.
# Do NOT use this branch for production. Real Entra sign-in is configured via `.env.production` on `develop`/`master`.
VITE_AUTH_MODE=mock

# Keep the allowed-domain filter permissive so both mock accounts (@cabq.gov) pass ProtectedRoute.
VITE_ALLOWED_EMAIL_DOMAINS=cabq.gov
