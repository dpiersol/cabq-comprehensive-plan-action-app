# Azure Entra ID (SPA) — register a single-page app redirect to /auth/callback on each environment.
VITE_AZURE_CLIENT_ID=
VITE_AZURE_TENANT_ID=
# Optional explicit redirect (defaults to {origin}/auth/callback).
# VITE_AZURE_REDIRECT_URI=http://localhost:5173/auth/callback

# Comma-separated domains allowed after sign-in (default: cabq.gov only).
# VITE_ALLOWED_EMAIL_DOMAINS=cabq.gov

# Comma-separated Entra app role names treated as application admin (footer Admin Console link).
# VITE_ENTRA_ROLE_ADMIN=Application.Admin,comp-plan-admin

# Force mock buttons on the landing page (development only).
# VITE_AUTH_MODE=mock
