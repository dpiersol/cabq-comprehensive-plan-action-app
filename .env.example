# Azure Entra ID (SPA) — register a single-page app redirect to /auth/callback on each environment.
VITE_AZURE_CLIENT_ID=
VITE_AZURE_TENANT_ID=
# Optional explicit redirect (defaults to {origin}/auth/callback).
# VITE_AZURE_REDIRECT_URI=http://localhost:5173/auth/callback

# Comma-separated domains allowed after sign-in (default: cabq.gov only).
# VITE_ALLOWED_EMAIL_DOMAINS=cabq.gov

# Comma-separated Entra app role names treated as application admin (footer Admin Console link).
# VITE_ENTRA_ROLE_ADMIN=Application.Admin,comp-plan-admin

# Force mock buttons on the landing page (development only).
# VITE_AUTH_MODE=mock

# API server (npm run dev:server) — SQLite file for persisted submissions.
# Defaults to ./data/submissions.sqlite (directory is gitignored).
# SQLITE_PATH=C:/apps/cabq-plan/data/submissions.sqlite

# --- API: validate Entra access tokens (recommended for production) ---
# AZURE_TENANT_ID=<Entra tenant GUID>
# AZURE_AUDIENCE=<Application ID URI or client id expected in token `aud` claim>
# Optional issuer override (default: https://login.microsoftonline.com/${AZURE_TENANT_ID}/v2.0)
# AZURE_ISSUER=
# While migrating or for sandbox without exposed API scope, allow X-User-* headers with JWT mode:
# ALLOW_HEADER_IDENTITY=true

# SPA: delegated scope used with acquireTokenSilent (must match Expose an API in Entra).
# VITE_API_SCOPE=api://<your-app-id>/access_as_user

# --- API: admin gate for /api/admin/submissions ---
# Entra app role names that grant admin (default: comp-plan-admin,Application.Admin,Admin)
# ADMIN_ROLE_NAMES=comp-plan-admin
# Comma-separated emails granted admin without an app role assignment (useful pre-Entra).
# ADMIN_EMAILS=alice@cabq.gov,bob@cabq.gov

# --- API: local admin accounts (independent of Entra) ---
# Secret used to sign HS256 local-session JWTs. 32+ random bytes. REQUIRED to enable local sign-in.
# LOCAL_JWT_SECRET=<openssl rand -base64 48>
# Session length in seconds (default 28800 = 8 h). 60..86400.
# LOCAL_JWT_TTL_SECONDS=28800
# Failed-login lockout policy.
# LOCAL_LOGIN_MAX_FAILS=5
# LOCAL_LOGIN_LOCK_MINUTES=15
# First-run bootstrap admin (only used when local_users table is empty).
# BOOTSTRAP_ADMIN_USERNAME=admin
# BOOTSTRAP_ADMIN_EMAIL=ops@cabq.gov
# BOOTSTRAP_ADMIN_PASSWORD=<strong password; forced to change on first login>
# BOOTSTRAP_ADMIN_DISPLAY=Local Administrator
